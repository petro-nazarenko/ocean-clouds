# ── Telegram credentials ──────────────────────────────────────────────────
# Get these from https://my.telegram.org/apps
# Required only for Telegram channel/group fetching
TG_API_ID=your_api_id_here
TG_API_HASH=your_api_hash_here

# ── Optional tuning ───────────────────────────────────────────────────────
# Override cache TTL (hours)
# CACHE_TTL_HOURS=2
# TG_CACHE_TTL_HOURS=1

# ── Formspree (for landing page email alerts) ─────────────────────────────
# Create a free form at https://formspree.io and paste the form ID here
# Then replace YOUR_FORM_ID in docs/index.html
# FORMSPREE_FORM_ID=xyzabcde
